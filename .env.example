# ─────────────────────────────────────────────────────────────────
#  ConnectWithAllCode — Telegram Adapter Configuration
# ─────────────────────────────────────────────────────────────────

# [REQUIRED] Your Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=

# [OPTIONAL] Comma-separated Telegram chat IDs allowed to use the bot.
# To find your chat ID: message @userinfobot on Telegram.
# If EMPTY, ALL chats are accepted (not recommended for production).
# ALLOWLIST_CHAT_IDS=123456789,987654321

# [OPTIONAL] Port for the internal WebSocket server (default: 3001)
# The connector will connect to ws://localhost:PORT/ws
PORT=3001

# [OPTIONAL] Path where cwac connect-with-all-code was cloned.
# Only used by install.sh, not the gateway process itself.
CWAC_PATH=/root/connect-with-all-code
